<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Início</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light d-flex justify-content-center align-items-center vh-100">

    <div class="container text-center">
        <div class="row justify-content-center">

            <!-- Card Cadastro -->
            <div class="col-md-4">
                <div class="card shadow p-4 mb-4">
                    <h3 class="mb-3">Criar Conta</h3>
                    <p class="text-muted">Cadastre-se para começar</p>
                    <a href="/cadastro" class="btn btn-success w-100">Cadastrar</a>
                </div>
            </div>

            <!-- Card Login -->
            <div class="col-md-4">
                <div class="card shadow p-4 mb-4">
                    <h3 class="mb-3">Entrar</h3>
                    <p class="text-muted">Já tem uma conta?</p>
                    <a href="/entrar" class="btn btn-primary w-100">Entrar</a>
                </div>
            </div>

            <!-- Card produtos maneiros -->
            <div class="col-md-4">
                <div class="card shadow p-4 mb-4">
                    <h3 class="mb-3">add porduto</h3>
                    <p class="text-muted">Adicione um porduto</p>
                    <a href="/cadastroP" class="btn btn-secondary w-100">adicionar</a>
                </div>
            </div>

        </div>
    </div>

</body>
</html>